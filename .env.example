# الأطرقجي - متجر السجاد والأثاث والمفروشات
# ==========================================
# انسخ هذا الملف إلى .env和非 الملء القيم المناسبة
# cp .env.example .env

APP_NAME="الأطرقجي - لوحة التحكم"
APP_ENV=production            # غيّر إلى production في الإنتاج الفعلي
APP_KEY=                      # شغّل: php artisan key:generate
APP_DEBUG=false               # true للتطوير، false للإنتاج
APP_TIMEZONE=Asia/Baghdad
APP_URL=https://your-domain.com  # غيّر إلى رابط المتجر الفعلي

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_IQ

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # غيّر إلى warning أو error في الإنتاج

# قاعدة البيانات - استخدم SQLite محلياً أو PostgreSQL/MySQL في الإنتاج
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=alatraqji
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# SMTP - غيّر إلى إعدادات الإيميل الفعلية
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# توكن Sanctum - صلاحية التوكن بالدقائق
SANCTUM_TOKEN_EXPIRATION=10080
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://your-store.com

# Sentry - لمراقبة الأخطاء (اختياري)
SENTRY_LARAVEL_DSN=

# AWS - للرفع إلى S3 (اختياري)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=me-south-1
# AWS_BUCKET=alatraqji-assets
